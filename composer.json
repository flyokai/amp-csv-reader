{
    "name": "flyokai/amp-csv-reader",
    "description": "Async csv file reader using amphp",
    "require": {
        "php": "^8.1",
        "amphp/amp": "^3",
        "amphp/file": "^3",
        "amphp/parser": "^1"
    },
    "license": [
        "MIT"
    ],
    "autoload": {
        "files": [
            "src/functions.php"
        ],
        "psr-4": {
            "Flyokai\\AmpCsvReader\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-dev-main": "1.1.x-dev",
            "dev-main": "1.1.x-dev"
        }
    }
}
